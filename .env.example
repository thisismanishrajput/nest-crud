# MongoDB connection
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster>.mongodb.net/<db_name>?retryWrites=true&w=majority

# JWT configuration
JWT_SECRET=your_jwt_secret

# App settings
PORT=3000

# SMTP mail settings for OTP verification (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=no-reply@yourdomain.com
# Note: For Gmail, use an App Password and make sure the account allows SMTP access.
